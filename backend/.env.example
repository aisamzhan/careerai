# Copy to ".env" and fill values. Do not commit real secrets.
OPENAI_API_KEY=sk-...

# Optional: default is gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: keep AI answers short (default in code: 240)
OPENAI_MAX_OUTPUT_TOKENS=240

# Optional: backend port (most hosts provide PORT automatically)
PORT=3000

# Optional: restrict CORS origins (comma-separated). Example:
# CORS_ORIGIN=https://your-site.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=

# Optional: include a short resume text preview in /api/resume/parse response (privacy)
RESUME_DEBUG_PREVIEW=0
